{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/uploads/(.*)",
      "dest": "/api/uploads",
      "methods": ["GET", "HEAD", "OPTIONS"]
    }
  ],
  "env": {
    "MYSQLHOST": "@mysqlhost",
    "MYSQLUSER": "@mysqluser", 
    "MYSQLPASSWORD": "@mysqlpassword",
    "MYSQLDATABASE": "@mysqldatabase",
    "MYSQLPORT": "@mysqlport"
  }
}
